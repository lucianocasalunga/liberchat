# LiberChat - Environment Variables

# Flask
FLASK_ENV=production
SECRET_KEY=change-this-secret-key
DEBUG=False

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=liberchat
DB_USER=liberchat
DB_PASSWORD=change-this-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Nostr
DEFAULT_RELAYS=wss://relay.libernet.app,wss://relay.damus.io,wss://nos.lol
NIP05_DOMAIN=libernet.app

# Lightning (LNbits)
LNBITS_URL=https://legend.lnbits.com
LNBITS_ADMIN_KEY=your-admin-key
LNBITS_INVOICE_KEY=your-invoice-key

# Application
APP_NAME=LiberChat
APP_URL=https://chat.libernet.app
PORT=5052
